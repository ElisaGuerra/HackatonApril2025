<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment_map">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/border_search"
            android:paddingTop="15dp"
            android:paddingBottom="10dp"
            android:scaleX="1"
            android:src="@drawable/search" />

        <ImageView
            android:id="@+id/big_map"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:background="#F2F3F7"
            android:src="@drawable/big_map_png" />

        <LinearLayout
            android:id="@+id/general_map"
            android:layout_width="325dp"
            android:layout_height="140dp"
            android:background="@drawable/border_types"
            android:orientation="vertical"
            android:layout_marginTop="15dp">

            <LinearLayout
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/plastic_dir"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="15dp"
                    android:src="@drawable/plastic" />

                <LinearLayout
                    android:id="@+id/punto"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/Teposa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teposa"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/terminados"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Terminados Plásticos de Occidente"
                        android:textColor="@color/black" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/long_dir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="5dp"
                android:text="45601, Iguala 99, San Sebastianito, 45601 San Pedro Tlaquepaque, Jal."
                android:textColor="@color/black"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/directions"
                android:layout_width="100dp"
                android:layout_height="25dp"
                android:layout_marginLeft="200dp"
                android:text="Directions"
                android:gravity="center"
                android:textColor="@color/white"
                android:background="@drawable/border_direction"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>
</FrameLayout>